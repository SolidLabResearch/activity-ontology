@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix vann: <http://purl.org/vocab/vann/>.
@prefix oaactivity: <https://openactive.io/activity-list#>.
@prefix activo: <https://solidlabresearch.github.io/activity-ontology#>.

<https://solidlabresearch.github.io/activity-ontology#> a owl:Ontology;
  dct:title "Sports Activity Ontology";
  rdfs:label "Sports Activity Ontology";
  dct:description "An OWL ontology for describing sports activity records and derived performance analytics. It models activities and laps, athlete settings, device and application provenance, activity type classification with SKOS/OpenActive mappings, and statistics for distance, time, speed, pace, power, heart rate, cadence, grade, elevation, dynamics, scores, zones, peaks, slopes, and data quality flags.";
  rdfs:comment "An OWL ontology for describing sports activity records and derived performance analytics. It models activities and laps, athlete settings, device and application provenance, activity type classification with SKOS/OpenActive mappings, and statistics for distance, time, speed, pace, power, heart rate, cadence, grade, elevation, dynamics, scores, zones, peaks, slopes, and data quality flags.";
  dct:creator "Maarten Vandenbrande (maarten.vandenbrande@ugent.be)";
  dct:license <https://opensource.org/license/mit>;
  dct:source <https://github.com/SolidLabResearch/activity-ontology>;
  vann:preferredNamespacePrefix "activo";
  owl:versionInfo "0.1";
  owl:imports <http://www.w3.org/ns/prov#>,
            <http://xmlns.com/foaf/0.1/>,
            <http://www.w3.org/2004/02/skos/core>,
            <http://purl.org/dc/terms/>.

# Provenance Integration Comment
# This ontology uses PROV-O (W3C Provenance Ontology) for modeling:
# - Device/source tracking (prov:wasGeneratedBy and prov:wasAssociatedWith)
# - Data transformation processes (prov:wasDerivedFrom)
# - Attribution (prov:wasAttributedTo)
# Activities are modeled as prov:Entity instances for full provenance support.
activo:StatsSubject a owl:Class;
  rdfs:label "Stats Subject";
  rdfs:comment "Something that can have statistics, such as an activity or lap.".

activo:Activity a owl:Class;
  rdfs:label "Activity";
  rdfs:comment "A model for defining an activity in sports.";
  rdfs:subClassOf prov:Entity,
    activo:StatsSubject.

# Activity type classification --------------------

activo:ActivityType a owl:Class;
  rdfs:label "Activity Type";
  rdfs:comment "A local activity type concept used to classify activities.";
  rdfs:subClassOf skos:Concept.

activo:ActivityTypeScheme a skos:ConceptScheme;
  skos:prefLabel "Activity Type Scheme"@en;
  rdfs:comment "Local activity type concepts for classifying activities, with exact matches to OpenActive Activity List concepts where available.";
  dct:source <https://openactive.io/activity-list/activity-list.jsonld>.

activo:AlpineSki a activo:ActivityType, skos:Concept;
  skos:prefLabel "Alpine Ski"@en;
  skos:inScheme activo:ActivityTypeScheme;
